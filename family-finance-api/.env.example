# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=family_finance_db
DB_SCHEMA=public
DB_USERNAME=family_finance_user
DB_PASSWORD=your_db_password_here

# JWT (generate: openssl rand -base64 32)
JWT_SECRET=your_jwt_secret_here

# Card Encryption (generate: openssl rand -base64 32)
CARD_ENCRYPTION_KEY=changeme_32_characters_minimum!!

# Super Admin — platforma operatori akkaunti boshlang'ich paroli.
# O'rnatilmasa 'superadmin' akkaunti yaratilmaydi. Birinchi login'da almashtiriladi.
SUPER_ADMIN_INITIAL_PASSWORD=changeme_strong_password
